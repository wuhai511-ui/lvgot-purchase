# ========== Server Configuration ==========
PORT=3000
NODE_ENV=development

# ========== CORS ==========
# 允许的跨域来源，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========== 安全加密 ==========
# AES-256-GCM 加密密钥（32字节，64个十六进制字符）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ========== JWT 认证 ==========
# JWT 签名密钥（生产环境务必使用强随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ========== 演示模式 ==========
# 设为 true 时登录为模拟模式（仅用于开发演示）
DEMO_MODE=true

# ========== 钱账通(QZT)配置 ==========
QZT_APP_ID=your-qzt-app-id
QZT_GATEWAY_URL=https://qztuat.xc-fintech.com/gateway/soa

# 私钥文件路径（运行时从环境变量读取，不再硬编码路径）
QZT_PRIVATE_KEY_PATH=bff-server/keys/private_key.pem
QZT_PUBLIC_KEY_PATH=bff-server/keys/cloud_public_key.pem

# ========== AI 能力（可选） ==========
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
