# 钱账通配置
QZT_APP_ID=your_app_id
QZT_GATEWAY_URL=https://qztuat.xc-fintech.com/gateway/soa
QZT_PRIVATE_KEY_PATH=./keys/private_key.pem
QZT_PUBLIC_KEY_PATH=./keys/cloud_public_key.pem

# 回调地址（用于钱账通回调通知）
# 必须是公网可访问的地址
QZT_CALLBACK_URL=https://your-domain.com

# 加密配置（AES-256-GCM，用于敏感字段加密存储）
# 64位十六进制字符串（32字节），生成方式：openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_encryption_key

# MiniMax AI API（用于智能分账）
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id

# 服务端口
PORT=3000

# CORS 白名单（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
